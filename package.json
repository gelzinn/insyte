{
  "name": "root",
  "private": true,
  "packageManager": "bun@1.2.13",
  "author": "gelzin <g@gelzin.com>",
  "description": "A flexible, developer-first analytics toolkit",
  "homepage": "https://insyte.gelzin.com/",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build --filter=*",
    "build:lib": "turbo run build --filter=analytics... --filter=@insyte/track...",
    "build:app": "cd apps/test && npm run build",
    "clean": "turbo run clean",
    "dev": "turbo run dev --filter=*",
    "dev:lib": "turbo run dev --filter=analytics... --filter=@insyte/track...",
    "dev:app": "cd apps/test && bun run dev",
    "start:app": "cd apps/test && bun run start",
    "type-check": "turbo run type-check",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "biome format .",
    "format:write": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "check:unsafe": "biome check --write --unsafe .",
    "example": "bun run example.ts",
    "setup-db": "bun run scripts/setup-database.ts",
    "migrate-db": "bun run scripts/migrate-database.ts",
    "test:app": "cd apps/test && bun run dev"
  },
  "keywords": [
    "typescript",
    "database",
    "analytics",
    "sql",
    "nosql",
    "mysql",
    "postgresql",
    "mongodb",
    "redis"
  ],
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.15.5",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0",
    "turbo": "^1.12.4",
    "tsup": "^8.0.2",
    "rimraf": "^5.0.5",
    "npm-run-all": "^4.1.5"
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "mongodb": "^6.0.0",
    "mysql2": "^3.6.0",
    "pg": "^8.11.0",
    "redis": "^4.6.0",
    "sqlite3": "^5.1.0"
  }
}
