{
  "name": "@insyte/cli",
  "version": "0.1.0",
  "description": "Insyte CLI — run Studio, scaffold projects (like prisma studio)",
  "license": "MIT",
  "type": "module",
  "bin": {
    "insyte": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "studio": "tsx src/index.ts studio",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@insyte/studio": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.0.2",
    "tsx": "^4.19.4",
    "typescript": "5.7.3"
  }
}
