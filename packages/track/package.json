{
  "name": "@insyte/track",
  "version": "0.2.0",
  "author": "gelzin <g@gelzin.com>",
  "description": "Unified analytics integration for JavaScript apps — GA4, Mixpanel, PostHog, Segment, and custom providers",
  "homepage": "https://insyte.gelzin.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gelzinn/insyte.git",
    "directory": "packages/track"
  },
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.js",
      "default": "./dist/react/index.mjs"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.mjs",
      "require": "./dist/vue/index.js",
      "default": "./dist/vue/index.mjs"
    },
    "./angular": {
      "types": "./dist/angular/index.d.ts",
      "import": "./dist/angular/index.mjs",
      "require": "./dist/angular/index.js",
      "default": "./dist/angular/index.mjs"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "import": "./dist/next/index.mjs",
      "require": "./dist/next/index.js",
      "default": "./dist/next/index.mjs"
    },
    "./next/client": {
      "types": "./dist/next/client.d.ts",
      "import": "./dist/next/client.mjs",
      "require": "./dist/next/client.js",
      "default": "./dist/next/client.mjs"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.mjs",
      "require": "./dist/providers/index.js",
      "default": "./dist/providers/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "tsup --dts --minify",
    "clean": "rimraf dist",
    "dev": "tsup --watch --dts"
  },
  "peerDependencies": {
    "@angular/core": ">=15",
    "next": ">=13",
    "react": ">=17",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "@angular/core": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@angular/core": "^19.2.0",
    "@types/react": "^19",
    "next": "^15.5.2",
    "react": "^19.1.0",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vue": "^3.5.13"
  },
  "keywords": [
    "analytics",
    "tracking",
    "google-analytics",
    "ga4",
    "mixpanel",
    "posthog",
    "segment",
    "amplitude",
    "plausible",
    "hotjar",
    "heap",
    "rudderstack",
    "gdpr",
    "consent",
    "react",
    "vue",
    "angular",
    "nextjs",
    "vite"
  ]
}
