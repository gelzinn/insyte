{
  "name": "insyte",
  "version": "0.0.1",
  "author": "gelzin <g@gelzin.com>",
  "description": "A flexible, developer-first analytics toolkit",
  "homepage": "https://insyte.gelzin.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gelzinn/insyte.git",
    "directory": "packages/insyte"
  },
  "bugs": {
    "url": "https://github.com/gelzinn/insyte/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "module": "./dist/index.mjs",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "tsup --dts --minify",
    "clean": "rimraf dist",
    "dev": "tsup --watch --dts",
    "lint": "run-p lint:*",
    "lint:eslint": "eslint src --ext .ts",
    "lint:eslint:fix": "eslint src --ext .ts --fix",
    "lint:format": "prettier --check \"src/**/*.ts\"",
    "lint:format:fix": "prettier --check \"src/**/*.ts\" --write",
    "lint:tsc": "tsc --project tsconfig.json --noEmit",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5.3.3",
    "tsup": "^8.0.2",
    "rimraf": "^5.0.5",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.2.5"
  },
  "dependencies": {
    "sqlite3": "^5.1.0"
  }
}
