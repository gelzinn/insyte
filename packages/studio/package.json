{
  "name": "@insyte/studio",
  "version": "0.1.0",
  "description": "Local analytics studio — browse unified, standardized analytics data",
  "license": "MIT",
  "type": "module",
  "bin": {
    "insyte-studio": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && vite build",
    "build:ui": "vite build",
    "predev": "( test -f ../analytics/dist/index.mjs || bun run --cwd ../analytics build ) && ( test -f dist/ui/index.html || bun run build:ui )",
    "dev": "tsx src/cli.ts --port 5555 --database ../../.insyte/analytics.db --no-open",
    "dev:ui": "vite",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@shadcn/react": "^0.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.7.11",
    "insyte": "workspace:*",
    "lucide-react": "^0.525.0",
    "radix-ui": "^1.6.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.11",
    "tsup": "^8.0.2",
    "tsx": "^4.19.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.7.3",
    "vite": "^6.0.0"
  }
}
